NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portfolio_db
# Development: keep true so Sequelize creates missing tables on startup (empty DB).
# If you see "column does not exist" after model changes, reset the Docker DB volume — see README "Fixing Sequelize schema mismatch".
DB_SYNC=true

JWT_ACCESS_SECRET=change-me-access-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12

FRONTEND_URL=http://localhost:5173
TRUST_PROXY=false

# --- SMTP (Gmail example) ---
# Use a Google "App Password" (2FA required): https://myaccount.google.com/apppasswords
# SMTP_PASS must be the 16-character app password, NOT your normal Gmail password.
# All of HOST, USER, PASS must be non-empty or the API logs codes to the console instead of sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraccount@gmail.com
SMTP_PASS=your-16-char-app-password
# Mailbox in From must match SMTP_USER for Gmail (e.g. InvestPro <youraccount@gmail.com>)
EMAIL_FROM=InvestPro <youraccount@gmail.com>

# BVMT scraping (falls back to mock prices on failure)
BVMT_SCRAPE_URL=https://www.bvmt.com.tn/en/cours
BVMT_CRON=*/7 * * * *
BVMT_TIMEOUT_MS=15000
# Optional JSON override: [{"ticker":"BIAT","name":"...","category":"Stock","price":12.5}]
BVMT_MOCK_JSON=

CRON_TZ=Africa/Tunis

# Optional: narrative for POST /api/ai/simulate (otherwise a built-in template is used)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Yahoo Finance (unofficial chart API) — portfolio expected return & simulator
# YAHOO_FINANCE_TIMEOUT_MS=12000
# YAHOO_FINANCE_USER_AGENT=Mozilla/5.0 ...
